# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log
yarn-error.log
yarn-debug.log
.yarn-integrity

# ── React Native ──────────────────────────────────────────────────────────────
# Metro bundler cache
.metro-health-check*
.metro-cache/

# Hermes compiled bytecode
*.hbc

# React Native CLI codegen output (these are regenerated on build)
android/app/build/generated/rncli/

# ── Android ───────────────────────────────────────────────────────────────────
# Gradle build outputs and caches
android/app/build/
android/.gradle/
android/local.properties

# Gradle wrapper jar (keep .properties so others use the same version)
android/gradle/wrapper/gradle-wrapper.jar

# Signing keystore files (keep debug.keystore for CI convenience, ignore release)
android/app/release.keystore
android/app/*.jks
*.keystore
!android/app/debug.keystore

# ── iOS ───────────────────────────────────────────────────────────────────────
ios/Pods/
ios/build/
ios/*.xcworkspace
ios/Podfile.lock
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
dist/
lib/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
google-services.json
GoogleService-Info.plist

# ── Editor & OS ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ──────────────────────────────────────────────────────────────────────
coverage/
.cache/
buck-out/
\.buckd/
*.orig
__pycache__/